{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build all",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "src/Cpu6502.Apple1/Cpu6502.Apple1.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Build Apple-1 emulator"
    },
    {
      "label": "run woziaczek",
      "command": "dotnet",
      "type": "process",
      "args": [
        "run",
        "--project",
        "src/Cpu6502.Apple1/Cpu6502.Apple1.csproj"
      ],
      "dependsOn": ["build all"],
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "echo": true,
        "focus": false,
        "panel": "shared"
      },
      "group": "test",
      "detail": "Uruchom monitor Wozniaka (Apple-1)"
    }
  ]
}
